{
  "name": "library-management-backend",
  "version": "1.0.0",
  "description": "Library Management System Backend API",
  "main": "server.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "dev:verbose": "nodemon --verbose server.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "connection/",
      "middleware/",
      "routes/",
      "controllers/",
      "models/"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules/",
      "temp/",
      "logs/",
      "*.test.js",
      "*.spec.js"
    ],
    "delay": 1000,
    "verbose": false,
    "env": {
      "NODE_ENV": "development"
    },
    "events": {
      "restart": "echo '🔄 Server restarted due to file changes'"
    }
  },
  "keywords": [
    "library",
    "books",
    "api",
    "express",
    "mysql"
  ],
  "author": "Your Name",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "nodemailer": "^8.0.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
